rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===== ВСПОМОГАТЕЛЬНЫЕ ФУНКЦИИ =====

    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function getUserRole() {
      return isAuthenticated() ? getUserDoc().role : null;
    }

    function isActive() {
      return isAuthenticated() && getUserDoc().isActive == true;
    }

    function isAdmin() {
      return isActive() && getUserRole() == 'admin';
    }

    function isTeacher() {
      return isActive() && getUserRole() == 'teacher';
    }

    function isCanteen() {
      return isActive() && getUserRole() == 'canteen';
    }

    function hasPermission(permission) {
      return isActive() && permission in getUserDoc().permissions;
    }

    // ===== КОЛЛЕКЦИЯ ПОЛЬЗОВАТЕЛЕЙ =====

    match /users/{userId} {
      allow read: if isAdmin() || (isAuthenticated() && request.auth.uid == userId);
      allow create: if isAdmin();
      allow update: if isAdmin() || (
          isAuthenticated() &&
          request.auth.uid == userId &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['dismissedAppAnnouncementAt', 'lastLoginAt'])
      );
      allow delete: if isAdmin();
    }

    // ===== ПУБЛИЧНЫЕ РАСПИСАНИЯ =====

    match /publicSchedules/{document} {
      allow read: if true;
    }

    // ===== СПРАВОЧНИКИ (чтение для всех — нужно для гостевого просмотра) =====

    match /teachers/{document} { allow read: if true; }
    match /subjects/{document} { allow read: if true; }
    match /classes/{document} { allow read: if true; }
    match /rooms/{document} { allow read: if true; }
    match /schedule_sem1/{document} { allow read: if true; }
    match /schedule_sem2/{document} { allow read: if true; }
    match /config/settings { allow read: if true; }
    match /config/bells { allow read: if true; }

    // ===== СЕКРЕТЫ =====

    match /config/secrets {
      allow read, write: if isAdmin();
    }

    // ===== ЗАМЕНЫ =====

    match /substitutions/{document} {
      allow read: if isActive() && (isAdmin() || isTeacher() || isCanteen());
      allow write: if isActive() && (isAdmin() || hasPermission('edit_substitutions'));
      allow update: if isActive() && (isAdmin() || hasPermission('edit_substitutions'));
      allow delete: if isActive() && isAdmin();
    }

    // ===== ДЕЖУРСТВА =====

    match /duty_zones/{document} {
      allow read: if isActive() && (isAdmin() || isTeacher());
      allow write: if isActive() && (isAdmin() || hasPermission('edit_duty'));
      allow delete: if isActive() && isAdmin();
    }

    match /duty_schedule/{document} {
      allow read: if isActive() && (isAdmin() || isTeacher());
      allow write: if isActive() && (isAdmin() || hasPermission('edit_duty'));
      allow update: if isActive() && (isAdmin() || hasPermission('edit_duty'));
      allow delete: if isActive() && isAdmin();
    }

    // ===== ПИТАНИЕ =====

    match /nutrition_records/{document} {
      allow read: if isActive();
      allow write: if isActive() && (isAdmin() || hasPermission('edit_nutrition'));
      allow update: if isActive() && (isAdmin() || hasPermission('edit_nutrition'));
      allow delete: if isActive() && isAdmin();
    }

    // ===== ПРОПУСКИ =====

    match /absenteeism_records/{document} {
      allow read: if isActive() && (isAdmin() || isTeacher());
      allow write: if isActive() && (isAdmin() || hasPermission('edit_absenteeism'));
      allow update: if isActive() && (isAdmin() || hasPermission('edit_absenteeism'));
      allow delete: if isActive() && isAdmin();
    }

    // ===== ЖУРНАЛ АУДИТА =====

    match /audit_log/{document} {
      allow read, write: if isAdmin();
    }

    // ===== ЗАПАСНОЕ ПРАВИЛО ДЛЯ АДМИНА =====

    match /{document=**} {
      allow write: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
